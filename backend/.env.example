# Database (Postgres in production, SQLite for local dev)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini

# ClickUp
CLICKUP_WORKSPACE_ID=123456
CLICKUP_LIST_ID=123456
CLICKUP_DATE_FIELD_ID=00000000-0000-0000-0000-000000000000

# Secrets (generate fresh values, never reuse across environments)
ENCRYPTION_KEY=replace_with_fernet_key
ADMIN_TOKEN=replace_with_admin_token

# Public hostname of this service (NO trailing slash)
PUBLIC_URL=https://your-app.example.com

# Webhook signature replay tolerance (seconds)
WEBHOOK_TOLERANCE_SECONDS=300
